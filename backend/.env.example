# Server
PORT=4000

# Database — get a free PostgreSQL DB from railway.app
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Frontend URL (for CORS) — use http://localhost:3000 in development
CLIENT_URL=http://localhost:3000

# Judge0 API — we'll set this up in Stage 8
# Get your free key at: https://rapidapi.com/judge0-official/api/judge0-ce
JUDGE0_API_KEY=your_rapidapi_key_here
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com